{
  "version": 6,
  "configurePresets": [
    {
      "name": "windows-base",
      "description": "Target Windows with the Visual Studio development environment.",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl.exe",
        "CMAKE_CXX_COMPILER": "cl.exe",
        "INFOCELL_TTF_FONT_PATH": "C:/Windows/Fonts/",
        "INFOCELL_ARC_TRAINING_PATH": "${sourceParentDir}/ARC/data/training/",
        "INFOCELL_ARC_PRIZE_PATH": "${sourceParentDir}/arc-prize-2024/",
        "INFOCELL_CONAN_PATH_BASE": "${sourceParentDir}/conan"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "linux-base",
      "description": "Target Linux with the gcc compiler and ninja build.",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "INFOCELL_TTF_FONT_PATH": "${sourceParentDir}",
        "INFOCELL_ARC_TRAINING_PATH": "${sourceParentDir}/ARC/data/training/",
        "INFOCELL_ARC_PRIZE_PATH": "${sourceParentDir}/arc-prize-2024/",
        "INFOCELL_CONAN_PATH_BASE": "${sourceParentDir}/conan"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "LinuxDebug",
      "displayName": "Debug",
      "description": "Target Linux (64-bit) with the g++ compiler. (Debug)",
      "inherits": "linux-base",
      "binaryDir": "${sourceDir}/build/Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "LinuxRelease",
      "displayName": "Release",
      "description": "Target Linux (64-bit) with the g++ compiler. (Release)",
      "inherits": "linux-base",
      "binaryDir": "${sourceDir}/build/Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "WinDebug",
      "displayName": "Debug",
      "description": "Target Windows (64-bit) with the Visual Studio development environment. (Debug)",
      "inherits": "windows-base",
      "binaryDir": "${sourceDir}/build/Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "WinRelease",
      "displayName": "Release",
      "description": "Target Windows (64-bit) with the Visual Studio development environment. (Release)",
      "inherits": "windows-base",
      "binaryDir": "${sourceDir}/build/Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "WinRelWithDebInfo",
      "displayName": "RelWithDebInfo",
      "description": "Target Windows (64-bit) with the Visual Studio development environment. (RelWithDebInfo)",
      "inherits": "windows-base",
      "binaryDir": "${sourceDir}/build/RelWithDebInfo",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "LinuxDebug",
      "displayName": "Linux Debug Build",
      "configurePreset": "LinuxDebug"
    },
    {
      "name": "LinuxRelease",
      "displayName": "Linux Release Build",
      "configurePreset": "LinuxRelease"
    }
  ]
}